generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Order {
  id        String      @id @default(uuid())
  userId    String
  total     Float
  status    OrderStatus @default(PENDING_PAYMENT)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model FailedMessage {
  id          String   @id @default(uuid())
  queue       String
  routingKey  String
  payload     Json
  error       String?
  createdAt   DateTime @default(now())

  @@map("failed_messages")
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  CANCELLED
  FAILED
}
